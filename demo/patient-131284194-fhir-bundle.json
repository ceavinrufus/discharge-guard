        "authoredOn": "2023-01-10",
        "note": [
          {
            "text": "CASCADE 1 Drug A: CCB causes peripheral edema (very common at 10mg, ~10-15% incidence). High severity: furosemide causes electrolyte depletion, renal stress, falls in elderly."
          }
        ],
        "dosageInstruction": [
          {
            "text": "10 MG once daily"
          }

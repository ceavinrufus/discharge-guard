{
  "name": "discharge-guard",
  "version": "1.0.0",
  "description": "MCP server for preventing medication errors at hospital discharge",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "npx tsx src/index.ts",
    "build": "tsc",
    "dev": "npx tsx src/index.ts",
    "dev:http": "PORT=3001 npx tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@smile-cdr/fhirts": "^2.3.0",
    "axios": "^1.7.2",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "jose": "^6.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.9",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "fhir",
    "healthcare",
    "medication-safety",
    "drug-interactions"
  ],
  "author": "DischargeGuard Team",
  "license": "MIT"
}
